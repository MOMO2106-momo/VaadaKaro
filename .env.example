# Required
DATABASE_URL="postgresql://user:pass@localhost:5432/vaadakaro"
AUTH_SECRET="<random 32+ char string>"
NEXTAUTH_URL="http://localhost:3000"

# Gemini API Keys — split by workload to avoid quota exhaustion
# CHAT: Civic Copilot multi-turn conversations (/ai-assistant)
GEMINI_API_KEY_CHAT="<Google AI Studio key for chat>"
# ANALYSIS: Complaint scoring, health checks, intelligence summaries
GEMINI_API_KEY_ANALYSIS="<Google AI Studio key for analysis>"
# DOCUMENTS: Legal document generation (/generate-docs)
GEMINI_API_KEY_DOCUMENTS="<Google AI Studio key for documents>"

# Legacy fallback — used only if the role-specific keys above are not set
# GEMINI_API_KEY=""

# Optional — Cloudinary (complaint photo uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional — SMTP (email notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
GOVT_EMAIL_GENERAL=""

# Legacy — no longer used (migrated to GEMINI_API_KEY)
# NEXT_PUBLIC_OPENROUTER_KEY=""
